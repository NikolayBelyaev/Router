@page "/"

<PageTitle>Routing Configuration</PageTitle>

<div class="container py-4">
    <div class="mx-auto" style="max-width: 1440px;">

        <h4 class="mb-4 fw-semibold">Routing Configuration</h4>

        @if (_validationResult is { IsValid: false })
        {
            <div class="alert alert-danger mb-4" role="alert">
                <h6 class="alert-heading fw-semibold mb-2">Errors</h6>
                <ul class="mb-0">
                    @foreach (var error in _validationResult.Errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }
        
        @if (_isLoading)
        {
            <div class="d-flex justify-content-center align-items-center" style="height:200px">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center">

                <ul class="nav nav-pills mb-4" id="routing-tab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="routing-tab-btn" data-bs-toggle="pill"
                                data-bs-target="#routing-tab-pane" type="button" role="tab">
                            Routing Rules
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="maintenance-tab-btn" data-bs-toggle="pill"
                                data-bs-target="#maintenance-tab-pane" type="button" role="tab">
                            Maintenance
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="targets-tab-btn" data-bs-toggle="pill"
                                data-bs-target="#targets-tab-pane" type="button" role="tab">
                            Targets
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="information-tab-btn" data-bs-toggle="pill"
                                data-bs-target="#information-tab-pane" type="button" role="tab">
                            Information
                        </button>
                    </li>
                </ul>

                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ReloadPage">
                        Discard Changes
                    </button>
                    <button class="btn btn-primary btn-sm" @onclick="OnApply">
                        Apply
                    </button>
                    <ConfirmationModal @ref="_configurationModal" Title="Apply Changes" Message="Are you sure you want to apply changes?" OnConfirmed="Apply" />

                </div>
            </div>

            <div class="tab-content">

                <div class="tab-pane fade show active" id="routing-tab-pane" role="tabpanel">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <Routing TargetsNames="_targetsNames" OnAddServer="RoutingService.AddServer"
                                     OnRemoveServer="RoutingService.RemoveServer" OnChanged="StateHasChanged"/>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="maintenance-tab-pane" role="tabpanel">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <Maintenance OnChanged="OnTargetsChanged"/>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="targets-tab-pane" role="tabpanel">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <Targets OnChanged="OnTargetsChanged"/>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="information-tab-pane" role="tabpanel">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <Information/>
                        </div>
                    </div>
                </div>

            </div>
        }

    </div>
</div>